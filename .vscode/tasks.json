{
    "version": "2.0.0",
    "tasks": [
       {
            "label": "run tests",
            "type": "shell",
            "command": "go",
            "args": [
                "test",
                "./...",
             ],
           "options": {
                "cwd": "${workspaceFolder}",
            }
        },
        {
            "label": "dump-db",
            "type": "shell",
            "command": "pg_dump",
            "args": [ 
                "-U",
                "postgres",
                "-d",
                "${input:dbName}",
                "-n",
                "auth",
                "-E",
                "UTF8",
                "-f",
                "auth_dump.sql"
            ],
           "options": {
                "cwd": "${workspaceFolder}/db/postgresql",
            }
        },
       {
            "label": "rename-db",
            "type": "shell",
            "command": "./renamedb",
            "args": [
                "postgres",
                "${input:dbName}",
             ],
            "options": {
                "cwd": "${workspaceFolder}/db/postgresql",
            },
        },
        {
            "label": "create-db",
            "type": "shell",
            "command": "psql",
            "args": [
                "-U",
                "postgres",
                "-d",
                "${input:dbName}",
                "-f",
                "auth_dump.sql"
            ],
            "options": {
                "cwd": "${workspaceFolder}/db/postgresql",
            },
        },
    ],
    "inputs": [
        {
            "id": "dbName",
            "type": "promptString",
            "description": "Database name",
            "default": "postgres"
        }
    ]
}