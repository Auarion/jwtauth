{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dump-db",
            "type": "shell",
            "command": "pg_dump -U postgres -d ComelitPL -n public > public_dump.sql",
            "options": {
                "cwd": "${workspaceFolder}/db/postgresql",
            }
        },
        {
            "label": "create-db",
            "type": "shell",
            "command": "psql",
            "args": [
                "-U",
                "postgres",
                "-d",
                "${input:dbName}",
                "-f",
                "create-auth-schema.sql"
            ],
            "options": {
                "cwd": "${workspaceFolder}/db/postgresql",
            },
        },
    ],
    "inputs": [
        {
            "id": "dbName",
            "type": "promptString",
            "description": "Database name",
            "default": "postgres"
        }
    ]
}